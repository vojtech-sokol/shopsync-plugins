             "properties": {
              "token": {
               "type": "string",
               "description": "Unikátní identifikátor zálohy pro následné operace (např. obnovu)."
              },
              "creation_time": {
               "type": "string",
               "format": "date-time",
               "description": "Datum a čas vytvoření zálohy.",
               "example": "2026-04-28T13:57:48+02:00",
               "__$ref": "#/components/schemas/DateTime"
              },
              "type": {
               "type": "string",
               "enum": [
                "manual",
                "system.updateFinal",
                "system.updateConfigurator",
                "system.disableConfigurator",
                "system.enableConfigurator"
               ],
               "description": "Typ zálohy:\n* `manual` - ručně vytvořena.\n* `system.updateFinal` - vzniká při překlopení testovací verze grafiky na ostrou.\n* `system.updateConfigurator` - změna verze grafiky (obsahuje info o verzích v additional_data).\n* `system.disableConfigurator` - vypnutí Designeru / zapnutí editoru kódu.\n* `system.enableConfigurator` - zapnutí Designeru / vypnutí editoru kódu."
              },
              "additional_data": {
               "type": "array",
               "description": "Dodatečné informace (např. u změny konfigurátoru obsahuje pole \"from\" a \"to\").",
               "items": {
                "type": "object"
               }
              },
              "name": {
               "type": "string",
               "description": "Název zálohy. Vrací se pouze v případě, že `type` = `manual`."
              },
              "expiration_time": {
               "type": "string",
               "format": "date-time",
               "description": "Datum expirace zálohy. Vrací se pouze u systémových záloh.",
               "example": "2026-04-28T13:57:48+02:00",
               "__$ref": "#/components/schemas/DateTime"
              }
             }
            }
           },
